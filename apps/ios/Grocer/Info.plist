<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Grocer</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>42</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>org.narro.grocer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>grocer</string>
			</array>
		</dict>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	<!-- Periodic catch-up sync for changes whose silent push iOS throttled or
	     dropped while backgrounded. See AppDelegate (BGAppRefreshTask). -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>org.narro.grocer.refresh</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>SystemBackgroundColor</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Gates CloudKit (see CloudKitService). Driven by GR_CLOUDKIT_ENABLED. -->
	<key>GRCloudKitEnabled</key>
	<string>$(GR_CLOUDKIT_ENABLED)</string>
	<!-- PostHog client config (see PostHogConfiguration). -->
	<key>GRPostHogProjectToken</key>
	<string>$(POSTHOG_PROJECT_TOKEN)</string>
	<key>GRPostHogHost</key>
	<string>$(POSTHOG_HOST)</string>
	<!-- HMAC key for optional Live Activity Worker calls. Set
	     LIVE_ACTIVITY_API_SECRET in build settings / xcconfig for signed builds. -->
	<key>GRLiveActivityAPISecret</key>
	<string>$(LIVE_ACTIVITY_API_SECRET)</string>
	<!-- Declares Grocer as a CloudKit share handler so tapping an iCloud
	     share link routes to userDidAcceptCloudKitShareWith (see
	     ShareAcceptance.swift) instead of falling back to an App Store lookup. -->
	<key>CKSharingSupported</key>
	<true/>
	<!-- Required for Live Activities. -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<!-- Shown when the app first touches iCloud. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>Grocer keeps your family grocery list in sync with iCloud.</string>
	<!-- Shown when inviting people: we read contacts only to let you pick
	     who to send a list invite to. Contacts never leave your device. -->
	<key>NSContactsUsageDescription</key>
	<string>Grocer uses your contacts so you can pick family and friends to invite to a list. Your contacts stay on your device.</string>
	<!-- Shown when linking a list to a store. Location is used on-device to
	     remind you to start a trip when you arrive — it is never sent to a
	     server. "Always" lets the reminder fire while Grocer is backgrounded. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Grocer uses your location to remind you to start a shopping trip when you arrive at a list's store. Your location stays on your device.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Grocer uses your location in the background to remind you to start a shopping trip when you arrive at a list's store. Your location stays on your device.</string>
	<!-- Shown when taking a photo of an item to identify it. The photo is sent
	     once to identify the item, then stored with the item in your shared
	     iCloud list. -->
	<key>NSCameraUsageDescription</key>
	<string>Grocer uses your camera to take a photo of a grocery item and identify it. The photo is saved with the item in your shared list.</string>
	<!-- Shown when picking an item photo from your library (e.g. on devices
	     without a camera). -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Grocer lets you choose a photo of a grocery item to identify it and save it with the item in your shared list.</string>
	<!-- App Store export compliance: only exempt encryption (HTTPS, etc.). -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
