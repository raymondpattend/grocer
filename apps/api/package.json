{
  "name": "@grocer/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler d1 migrations apply grocer --local && sh -c 'node scripts/apns-http2-bridge.mjs & bridge_pid=$!; trap \"kill $bridge_pid 2>/dev/null\" EXIT; wrangler dev --var APNS_HTTP2_BRIDGE_URL:http://127.0.0.1:${APNS_HTTP2_BRIDGE_PORT:-8791}'",
    "dev:worker": "wrangler d1 migrations apply grocer --local && wrangler dev",
    "apns:bridge": "node scripts/apns-http2-bridge.mjs",
    "seed:images": "node scripts/seed-product-images.mjs",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply grocer --local",
    "db:migrate:remote": "wrangler d1 migrations apply grocer --remote"
  },
  "dependencies": {
    "@grocer/shared": "workspace:*",
    "@sentry/cloudflare": "^10.56.0",
    "@sentry/hono": "^10.56.0",
    "grafana-openai-monitoring": "^0.0.4",
    "hono": "^4.6.3",
    "openai": "^6.42.0",
    "posthog-node": "^5.0.0",
    "stripe": "^22.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "wrangler": "^3.78.0"
  }
}
