# Copy to `.dev.vars` for local `wrangler dev`. NEVER commit the real file.
#
# The APNs auth key is the contents of the AuthKey_XXXXXXXXXX.p8 file you
# download from the Apple Developer portal. Paste it with literal \n escapes
# OR as a real multi-line value (wrangler supports multi-line .dev.vars).

APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"

# These can also live in wrangler.toml [vars]; values here override for local dev.
APNS_ENVIRONMENT="sandbox"
APNS_TEAM_ID="ABCDE12345"
APNS_KEY_ID="FGHIJ67890"
APNS_BUNDLE_ID="org.narro.grocer"

IOS_MIN_BUILD="1"
IOS_LATEST_BUILD="1"
IOS_UPDATE_URL="https://narro.org/grocer"
IOS_EXTERNAL_PURCHASE_STOREFRONTS="USA"

# Stripe / RevenueCat web checkout. Use Stripe test mode values locally.
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_KEY"
STRIPE_PRICE_ANNUAL="price_REPLACE_ANNUAL"
STRIPE_PRICE_QUARTERLY="price_REPLACE_QUARTERLY"
STRIPE_PRICE_MONTHLY="price_REPLACE_MONTHLY"

# Local Wrangler/Miniflare fetch cannot speak APNs' required HTTP/2 transport.
# `pnpm dev:api` starts this bridge automatically and injects the URL with
# `wrangler dev --var`; set it manually only if you run Wrangler yourself.
APNS_HTTP2_BRIDGE_URL="http://127.0.0.1:8791"

# OpenAI — used for product image generation (gpt-image-1)
OPENAI_API_KEY="sk-REPLACE_WITH_YOUR_KEY"

# Grafana OpenAI monitoring. Store the real access token with
# `wrangler secret put GRAFANA_CLOUD_ACCESS_TOKEN` in production.
GRAFANA_OPENAI_METRICS_URL="https://prometheus-prod-56-prod-us-east-2.grafana.net/api/prom"
GRAFANA_OPENAI_LOGS_URL="https://logs-prod-036.grafana.net/loki/api/v1/push"
GRAFANA_OPENAI_METRICS_USERNAME="3311740"
GRAFANA_OPENAI_LOGS_USERNAME="1651545"
GRAFANA_CLOUD_ACCESS_TOKEN="glc_REPLACE_WITH_YOUR_TOKEN"

# Shared HMAC key for app-signed /live-activity/* requests. Must match
# LIVE_ACTIVITY_API_SECRET in apps/ios/Config/Secrets.xcconfig.
LIVE_ACTIVITY_API_SECRET="generate-with-openssl-rand-hex-32"
